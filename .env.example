# ============================================================
# The Rain Church Global — Environment variables
# Copy this file to ".env.local" and fill in the real values.
# .env.local is gitignored and never committed.
# ============================================================

# --- Supabase ---
# Create a free project at https://supabase.com, then find these under
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# The "anon" public key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# The "service_role" secret key — SERVER ONLY. Never expose this to the browser
# and never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Admin dashboard ---
# The single shared password used to sign in at /admin.
ADMIN_PASSWORD=change-this-to-a-strong-password
# A long random string used to sign the admin session cookie.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# --- Storage ---
# Name of the Supabase Storage bucket for uploaded media (create it as public).
NEXT_PUBLIC_SUPABASE_MEDIA_BUCKET=media
